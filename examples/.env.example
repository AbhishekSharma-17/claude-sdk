# Claude Agent SDK — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── Authentication (pick ONE method) ──────────────────────────────────────────

# Method 1: Direct Anthropic API (simplest)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Method 2: AWS Bedrock
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_PROFILE=my-profile
# AWS_REGION=us-east-1
# # OR use explicit keys:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Method 3: Google Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
# GOOGLE_CLOUD_PROJECT=my-project

# Method 4: Azure AI Foundry
# CLAUDE_CODE_USE_FOUNDRY=1

# ── Model Configuration ──────────────────────────────────────────────────────

# Model aliases: "haiku", "sonnet", "opus"
# Full IDs: "claude-opus-4-6", "claude-sonnet-4-6", "claude-haiku-4-5-20251001"
CLAUDE_MODEL=sonnet

# ── Cost Control ──────────────────────────────────────────────────────────────

MAX_BUDGET_USD=1.0
